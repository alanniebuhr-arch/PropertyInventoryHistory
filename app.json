{
  "expo": {
    "name": "Property Asset Manager",
    "slug": "PropertyInventoryHistory",
    "version": "1.3.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f6f8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alanniebuhr.propertyinventoryhistory",
      "buildNumber": "18",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Take photos of property assets for your inventory.",
        "NSPhotoLibraryUsageDescription": "Attach photos of property assets to your inventory.",
        "NSFaceIDUsageDescription": "Unlock protected rooms in your property inventory."
      }
    },
    "android": {
      "versionCode": 13,
      "adaptiveIcon": {
        "backgroundColor": "#1f5fbf",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach photos of property assets to your inventory.",
          "cameraPermission": "Take photos of property assets for your inventory."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "edc2eb70-f5d9-45d6-ab35-ce49c2aca812"
      }
    }
  }
}
